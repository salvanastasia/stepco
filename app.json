{
  "expo": {
    "name": "Stepco",
    "slug": "stepco",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "stepco",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stepco.app",
      "infoPlist": {
        "NSMotionUsageDescription": "This app uses the pedometer to track your steps during walks."
      }
    },
    "android": {
      "package": "com.stepco.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBra6HVLQ4OjVtKBrqoCPJ97-OKGn8imPk"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Stepco to use your location to track your walks."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Stepco to access motion and fitness data to count your steps."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "bf20f188-9755-4075-8841-b69449967557"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bf20f188-9755-4075-8841-b69449967557"
    }
  }
}
