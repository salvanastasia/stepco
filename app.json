{
  "expo": {
    "name": "Stepco",
    "slug": "stepco-ryd",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "stepco",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stepco.app",
      "infoPlist": {
        "NSMotionUsageDescription": "This app uses the pedometer to track your steps during walks.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stepco.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACTIVITY_RECOGNITION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Stepco to use your location to track your walks."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Stepco to access motion and fitness data to count your steps."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "e5d488c6-d633-4319-a304-e6c2c0eee8a8"
      }
    },
    "owner": "salvvv"
  }
}
